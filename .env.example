# --- Base de datos MySQL ---
# Crea antes una base de datos vacia, ej: CREATE DATABASE facturadiscord;
DATABASE_URL="mysql://user:password@localhost:3306/facturadiscord"

# --- Web (apps/web) ---
# Clave secreta para firmar la sesion. Genera una aleatoria larga (>=32 chars), ej: openssl rand -hex 32
SESSION_SECRET="change-me-to-a-long-random-string"

# Login con Discord (OAuth). Crea la app en https://discord.com/developers/applications
# y añade la Redirect URI (OAuth2 > Redirects) que apunte a /api/auth/discord/callback
DISCORD_CLIENT_SECRET="tu-client-secret-de-la-app"
DISCORD_OAUTH_REDIRECT_URI="https://tu-dominio.com/api/auth/discord/callback"

# --- Bot de Discord (apps/bot) ---
DISCORD_TOKEN="tu-token-del-bot"
DISCORD_CLIENT_ID="tu-client-id-de-la-app"
# Opcional: ID de un servidor de pruebas para que los comandos se registren al instante
# (sin esto, el registro global puede tardar hasta 1 hora en propagarse)
DISCORD_GUILD_ID=""

# --- Plataforma ---
# ID de Discord del super-admin: el UNICO que puede crear cuentas y dar acceso
# (/crear-cuenta, /listar-cuentas y el panel /admin de la web).
SUPER_ADMIN_DISCORD_ID="tu-id-de-discord"

# Opcional: credenciales de acceso web del super-admin (usuario/contrasena),
# por si quieres entrar sin Discord. El seed las aplica si estan presentes.
# Cada owner puede tener las suyas (las asigna el super-admin o el propio owner).
SUPER_ADMIN_USERNAME="admin"
SUPER_ADMIN_PASSWORD="cambia-esto-por-una-contrasena-larga"
