# --- Base de datos MySQL ---
# Crea antes una base de datos vacia, ej: CREATE DATABASE facturadiscord;
DATABASE_URL="mysql://user:password@localhost:3306/facturadiscord"

# --- Web (apps/web) ---
# Clave secreta para firmar la sesion de login. Genera una aleatoria larga, ej: openssl rand -hex 32
SESSION_SECRET="change-me-to-a-long-random-string"
# Usuario/contrasena creados por el script de seed (npm run db:seed)
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="change-me"

# --- Bot de Discord (apps/bot) ---
DISCORD_TOKEN="tu-token-del-bot"
DISCORD_CLIENT_ID="tu-client-id-de-la-app"
# Opcional: ID de un servidor de pruebas para que los comandos se registren al instante
# (sin esto, el registro global puede tardar hasta 1 hora en propagarse)
DISCORD_GUILD_ID=""
# Tu ID de usuario de Discord. Es el UNICO que puede usar /permitir y /revocar
OWNER_DISCORD_ID="tu-id-de-discord"
