generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

model CompanyProfile {
  id             Int      @id @default(autoincrement())
  name           String
  taxId          String?
  address        String?
  email          String?
  phone          String?
  iban           String?
  logoUrl        String?
  defaultTaxRate Decimal  @default(21) @db.Decimal(5, 2)
  notes          String?  @db.Text
  updatedAt      DateTime @updatedAt
}

model Client {
  id        Int        @id @default(autoincrement())
  name      String
  taxId     String?
  address   String?
  email     String?
  phone     String?
  createdAt DateTime   @default(now())
  documents Document[]
}

enum DocumentType {
  INVOICE
  QUOTE
}

enum DocumentStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  PAID
  EXPIRED
}

model Document {
  id       Int            @id @default(autoincrement())
  type     DocumentType
  number   String         @unique
  status   DocumentStatus @default(DRAFT)

  clientId Int
  client   Client         @relation(fields: [clientId], references: [id])

  issueDate DateTime      @default(now())
  dueDate   DateTime?
  notes     String?       @db.Text

  subtotal  Decimal       @db.Decimal(12, 2)
  taxAmount Decimal       @db.Decimal(12, 2)
  total     Decimal       @db.Decimal(12, 2)

  lines DocumentLine[]

  convertedFromId Int?      @unique
  convertedFrom   Document? @relation("QuoteToInvoice", fields: [convertedFromId], references: [id])
  convertedTo     Document? @relation("QuoteToInvoice")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([status])
}

model DocumentLine {
  id          Int      @id @default(autoincrement())
  documentId  Int
  document    Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  description String
  quantity    Decimal  @db.Decimal(10, 2)
  unitPrice   Decimal  @db.Decimal(12, 2)
  taxRate     Decimal  @db.Decimal(5, 2)
  lineTotal   Decimal  @db.Decimal(12, 2)
  position    Int      @default(0)
}

model DocumentCounter {
  id         Int          @id @default(autoincrement())
  type       DocumentType
  year       Int
  lastNumber Int          @default(0)

  @@unique([type, year])
}

model AllowedDiscordUser {
  id        Int      @id @default(autoincrement())
  discordId String   @unique
  label     String?
  addedBy   String
  addedAt   DateTime @default(now())
}
