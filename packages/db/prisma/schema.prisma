generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Cuentas / multi-inquilino
// ---------------------------------------------------------------------------

model Account {
  id        Int      @id @default(autoincrement())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company        CompanyProfile?
  members        AccountMember[]
  discordLinks   AccountDiscordLink[]
  paymentMethods PaymentMethod[]
  clients        Client[]
  documents      Document[]
  counters       DocumentCounter[]
}

model User {
  id        Int      @id @default(autoincrement())
  discordId String   @unique
  username  String
  avatar    String?
  createdAt DateTime @default(now())

  memberships AccountMember[]
}

enum MemberRole {
  OWNER
  MEMBER
}

model AccountMember {
  id        Int        @id @default(autoincrement())
  accountId Int
  account   Account    @relation(fields: [accountId], references: [id], onDelete: Cascade)
  userId    Int
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      MemberRole @default(MEMBER)
  createdAt DateTime   @default(now())

  @@unique([accountId, userId])
  @@index([userId])
}

// Un servidor de Discord (guild) pertenece a una sola cuenta.
model AccountDiscordLink {
  id        Int      @id @default(autoincrement())
  accountId Int
  account   Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  guildId   String   @unique
  guildName String?
  linkedBy  String
  createdAt DateTime @default(now())

  @@index([accountId])
}

model CompanyProfile {
  id             Int      @id @default(autoincrement())
  accountId      Int      @unique
  account        Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  name           String
  taxId          String?
  address        String?
  email          String?
  phone          String?
  iban           String?
  logoUrl        String?
  defaultTaxRate Decimal  @default(21) @db.Decimal(5, 2)
  notes          String?  @db.Text
  updatedAt      DateTime @updatedAt
}

enum PaymentMethodType {
  TRANSFER
  PAYPAL
  BIZUM
  CASH
  CARD
  OTHER
}

// Métodos de pago configurados por la cuenta (catálogo reutilizable).
model PaymentMethod {
  id        Int               @id @default(autoincrement())
  accountId Int
  account   Account           @relation(fields: [accountId], references: [id], onDelete: Cascade)
  type      PaymentMethodType
  label     String?
  details   String
  position  Int               @default(0)
  createdAt DateTime          @default(now())

  @@index([accountId])
}

model Client {
  id        Int        @id @default(autoincrement())
  accountId Int
  account   Account    @relation(fields: [accountId], references: [id], onDelete: Cascade)
  name      String
  taxId     String?
  address   String?
  email     String?
  phone     String?
  createdAt DateTime   @default(now())
  documents Document[]

  @@index([accountId])
}

enum DocumentType {
  INVOICE
  QUOTE
}

enum DocumentStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  PAID
  EXPIRED
}

model Document {
  id        Int            @id @default(autoincrement())
  accountId Int
  account   Account        @relation(fields: [accountId], references: [id], onDelete: Cascade)
  type      DocumentType
  number    String
  status    DocumentStatus @default(DRAFT)

  clientId Int
  client   Client @relation(fields: [clientId], references: [id])

  issueDate DateTime  @default(now())
  dueDate   DateTime?
  notes     String?   @db.Text

  subtotal  Decimal @db.Decimal(12, 2)
  taxAmount Decimal @db.Decimal(12, 2)
  total     Decimal @db.Decimal(12, 2)

  lines          DocumentLine[]
  paymentOptions DocumentPaymentOption[]

  convertedFromId Int?      @unique
  convertedFrom   Document? @relation("QuoteToInvoice", fields: [convertedFromId], references: [id])
  convertedTo     Document? @relation("QuoteToInvoice")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([accountId, number])
  @@index([accountId])
  @@index([type])
  @@index([status])
}

model DocumentLine {
  id          Int      @id @default(autoincrement())
  documentId  Int
  document    Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  description String
  quantity    Decimal  @db.Decimal(12, 4)
  unitPrice   Decimal  @db.Decimal(14, 4)
  taxRate     Decimal  @db.Decimal(5, 2)
  lineTotal   Decimal  @db.Decimal(12, 2)
  position    Int      @default(0)
}

// Snapshot inmutable de los métodos de pago elegidos al emitir el documento.
// No referencia a PaymentMethod: editar/borrar un método no altera documentos ya emitidos.
model DocumentPaymentOption {
  id         Int               @id @default(autoincrement())
  documentId Int
  document   Document          @relation(fields: [documentId], references: [id], onDelete: Cascade)
  type       PaymentMethodType
  label      String?
  details    String
  position   Int               @default(0)

  @@index([documentId])
}

model DocumentCounter {
  id         Int          @id @default(autoincrement())
  accountId  Int
  account    Account      @relation(fields: [accountId], references: [id], onDelete: Cascade)
  type       DocumentType
  year       Int
  lastNumber Int          @default(0)

  @@unique([accountId, type, year])
}
