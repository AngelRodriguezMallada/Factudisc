{
  "name": "facturadiscord",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev -w apps/web",
    "dev:bot": "npm run dev -w apps/bot",
    "build:web": "npm run build -w apps/web",
    "build:bot": "npm run build -w apps/bot",
    "build": "npm run build:web && npm run build:bot",
    "deploy:commands": "npm run deploy:commands -w apps/bot",
    "db:generate": "prisma generate --schema packages/db/prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema packages/db/prisma/schema.prisma",
    "db:seed": "tsx packages/db/src/seed.ts"
  }
}
